{
  "manifest_version": 3,
  "name": "RWL Capture",
  "version": "0.1.0",
  "description": "Save the current tab to RWL (Read · Watch · Listen).",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "options_page": "options.html",
  "icons": { "128": "icon.png" },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://rwl-api.vercel.app/*", "https://rwl.johnintrater.com/*"]
}
